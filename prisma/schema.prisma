// Yilow.ai Database Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ════════════════════════════════════════════════════════════════
// AUTH (NextAuth v5 + Credentials)
// ════════════════════════════════════════════════════════════════

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  passwordHash   String?   // bcrypt — null for OAuth-only users

  // Plan & credits
  plan           Plan      @default(FREE)
  creditsBalance Int       @default(100)   // seed bonus
  creditsLimit   Int       @default(100)   // plan monthly allowance
  planRenewsAt   DateTime?

  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  sessions           Session[]
  generations        Generation[]
  chatConversations  ChatConversation[]
  spaces             Space[]
  agentSubscriptions AgentSubscription[]
  creditTransactions CreditTransaction[]
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

// OAuth linked accounts (Google/GitHub)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ════════════════════════════════════════════════════════════════
// CREDITS
// ════════════════════════════════════════════════════════════════

model CreditTransaction {
  id        String          @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Int             // negative for deductions, positive for purchases/bonuses
  balanceAfter Int
  reason    String?         // tool id, purchase id, etc.
  metadata  Json?           // { toolId, toolName, generationId, stripePaymentId }
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum TransactionType {
  DEDUCTION       // tool usage
  PURCHASE        // bought credits pack
  SUBSCRIPTION    // monthly plan renewal bonus
  BONUS           // signup gift, referral
  REFUND          // failed generation
  ADJUSTMENT      // admin adjustment
}

// ════════════════════════════════════════════════════════════════
// GENERATIONS (tool outputs history)
// ════════════════════════════════════════════════════════════════

model Generation {
  id          String            @id @default(cuid())
  userId      String
  toolId      String            // matches src/lib/data/tools.ts id
  toolName    String            // cached for display
  category    String            // "image" | "video" | "audio"
  status      GenerationStatus  @default(PENDING)
  creditsUsed Int

  inputs      Json              // form inputs object
  outputs     Json?             // MuAPI response (urls, text, etc.)
  errorMessage String?

  muapiJobId  String?           // for polling long-running jobs
  durationMs  Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([toolId])
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ════════════════════════════════════════════════════════════════
// CHAT
// ════════════════════════════════════════════════════════════════

model ChatConversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("محادثة جديدة")
  model     String    // "claude-3-5-sonnet" | "gpt-4o" | "gemini-1.5-pro" | "llama-3"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           ChatRole
  content        String           @db.Text
  attachments    Json?            // array of file refs
  metadata       Json?            // tokens, model-specific, etc.
  createdAt      DateTime         @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

// ════════════════════════════════════════════════════════════════
// SPACES (collaboration canvas)
// ════════════════════════════════════════════════════════════════

model Space {
  id          String   @id @default(cuid())
  userId      String
  title       String   @default("مساحة جديدة")
  description String?
  thumbnail   String?  // auto-generated preview

  // @xyflow/react state
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  viewport    Json?    // { x, y, zoom }

  // sharing
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastOpenedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

// ════════════════════════════════════════════════════════════════
// AGENT SUBSCRIPTIONS (marketplace)
// ════════════════════════════════════════════════════════════════

model AgentSubscription {
  id              String              @id @default(cuid())
  userId          String
  agentId         String              // matches src/lib/data/agents.ts id
  agentName       String              // cached
  monthlyPriceUsd Decimal             @db.Decimal(10, 2)
  status          SubscriptionStatus  @default(ACTIVE)

  stripeSubscriptionId String? @unique

  startedAt   DateTime  @default(now())
  renewalDate DateTime?
  cancelledAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId])
  @@index([userId])
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  PAST_DUE
}

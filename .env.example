# ════════════════════════════════════════════════════════════════
# DATABASE — PostgreSQL connection string
# ════════════════════════════════════════════════════════════════
# For local dev run:  npx prisma dev
# Then copy the DATABASE_URL it prints here.
# For production, use your managed Postgres (Supabase, Neon, RDS...).
DATABASE_URL="postgres://user:pass@host:5432/yilow?sslmode=require"
SHADOW_DATABASE_URL="postgres://user:pass@host:5432/yilow_shadow?sslmode=require"

# ════════════════════════════════════════════════════════════════
# MuAPI — AI tools proxy
# ════════════════════════════════════════════════════════════════
MU_API_KEY="your-muapi-key"

# ════════════════════════════════════════════════════════════════
# NEXTAUTH v5
# ════════════════════════════════════════════════════════════════
# Generate a strong secret: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# OAuth (optional — only enabled when both ID + SECRET are set)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ════════════════════════════════════════════════════════════════
# AI CHAT — Vercel AI Gateway key
# ════════════════════════════════════════════════════════════════
# One key → routes to Anthropic/OpenAI/Google/etc via @ai-sdk/gateway.
# Without this the /api/chat endpoint returns 503.
AI_GATEWAY_API_KEY=""

# ════════════════════════════════════════════════════════════════
# STRIPE (future — billing not yet wired)
# ════════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
